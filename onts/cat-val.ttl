PREFIX :        <https://linked.data.gov.au/def/catalogue-validator/>
PREFIX catval:  <https://linked.data.gov.au/def/catalogue-validator>
PREFIX dash:    <http://datashapes.org/dash#>
PREFIX dcat:    <http://www.w3.org/ns/dcat#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX owl:     <http://www.w3.org/2002/07/owl#>
PREFIX prov:    <http://www.w3.org/ns/prov#>
PREFIX reg:     <http://purl.org/linked-data/registry#>
PREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:    <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema:  <https://schema.org/>
PREFIX sh:      <http://www.w3.org/ns/shacl#>
PREFIX skos:    <http://www.w3.org/2004/02/skos/core#>
PREFIX xsd:     <http://www.w3.org/2001/XMLSchema#>

catval: a owl:Ontology ;
    owl:versionIRI :1.0 ;
    owl:versionInfo "1.0 First version" ;
    schema:creator <https://linked.data.gov.au/org/dcceew> ;
    schema:dateCreated "2026-04-27"^^xsd:date ;
    schema:dateModified "2026-04-27"^^xsd:date ;
    skos:historyNote "Updated to conform with ValPub validator" ; 
    schema:description "SHACL validator for catalogue metadata using schema.org and DCAT-compatible patterns."@en ;
    schema:name "Catalogue Metadata Validator"@en ;



:CatalogueShape
    a sh:NodeShape ;
    sh:targetClass schema:DataCatalog ;
    sh:targetClass dcat:Catalog ;
    sh:property
        :CatalogueTitleShape ,
        :CatalogueDescriptionShape ,
        :CatalogueCreatedShape ,
        :CatalogueModifiedShape ,
        :CataloguePartsShape ;
.

:CatalogueTitleShape
    a sh:PropertyShape ;
    sh:path [
        sh:alternativePath (
            schema:name
            dcterms:title
        )
    ] ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:or (
        [ sh:datatype xsd:string ]
        [ sh:datatype rdf:langString ]
    ) ;
    sh:message "A catalogue SHALL have exactly one title or name, using schema:name or dcterms:title." ;
.

:CataloguePartsShape
    a sh:PropertyShape ;
    sh:path [
        sh:alternativePath (
            schema:hasPart
            dcat:dataset
            dcat:catalog
            dcterms:hasPart
        )
    ] ;
    sh:nodeKind sh:IRI ;
    sh:message "Catalogue members SHOULD be indicated using schema:hasPart, dcat:dataset, dcat:catalog, or dcterms:hasPart." ;
.


